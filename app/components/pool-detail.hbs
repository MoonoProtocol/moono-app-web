<section class="page-section">
  <div class="hero-card">
    <p class="section-label">Asset Pool</p>
    <h2>{{this.pool.mint}}</h2>
    <p class="hero-copy">
      Deposit liquidity into a specific tick page, monitor active LP positions,
      and withdraw shares from the same screen.
    </p>
    <div class="stats-grid">
      <article class="stat-card">
        <span>Total liquidity</span>
        <strong>{{this.pool.totalAvailableLiquidityFormatted}}</strong>
      </article>
      <article class="stat-card">
        <span>Total shares</span>
        <strong>{{this.pool.totalSharesFormatted}}</strong>
      </article>
      <article class="stat-card">
        <span>Deposits</span>
        <strong>{{if this.pool.allowDeposits "enabled" "disabled"}}</strong>
      </article>
      <article class="stat-card">
        <span>Borrows</span>
        <strong>{{if this.pool.allowBorrows "enabled" "disabled"}}</strong>
      </article>
    </div>
  </div>

  <section class="panel">
    <div class="panel-heading">
      <div>
        <p class="section-label">Deposit</p>
        <h3>Choose amount and APY</h3>
      </div>
    </div>

    {{#if this.hasAvailableTicks}}
      <article class="panel panel-subtle">
        <div class="deposit-builder deposit-builder-columns">
          <div class="deposit-column">
            <label class="input-field">
              <span>Deposit amount</span>
              <input
                type="text"
                value={{this.depositAmount}}
                placeholder="10"
                disabled={{this.depositDisabled}}
                {{on "input" this.updateDepositAmount}}
              />
            </label>

            <div class="slider-block">
              <label class="slider-input">
                <input
                  class="tick-slider"
                  type="range"
                  min="0"
                  max={{this.walletQuoteAssetBalanceMax}}
                  step={{this.walletQuoteAssetBalanceStep}}
                  value={{this.depositAmountSliderValue}}
                  disabled={{this.depositBalanceSliderDisabled}}
                  {{on "input" this.updateDepositAmountFromSlider}}
                />
              </label>

              <div class="slider-scale">
                <span>0</span>
                <span>{{this.walletQuoteAssetBalanceText}} {{this.pool.mintLabel}}</span>
              </div>
            </div>
          </div>

          <div class="deposit-column">
            <label class="input-field">
              <span>Selected APY</span>
              <input
                type="text"
                value={{this.selectedTickOption.apyLabel}}
                readonly
                disabled={{this.depositDisabled}}
              />
            </label>

            <div class="slider-block">
              <label class="slider-input">
                <input
                  class="tick-slider"
                  type="range"
                  min="0"
                  max={{this.sliderMax}}
                  step="1"
                  value={{this.selectedTickSliderValue}}
                  disabled={{this.depositDisabled}}
                  {{on "input" this.updateSelectedTickSliderValue}}
                />
              </label>

              <div class="slider-scale">
                <span>{{this.firstTickOption.apyLabel}}</span>
                <span>{{this.selectedTickOption.apyLabel}}</span>
                <span>{{this.lastTickOption.apyLabel}}</span>
              </div>
            </div>
          </div>

          <button
            type="button"
            class="button button-primary deposit-submit"
            disabled={{this.depositDisabled}}
            {{on "click" this.deposit}}
          >
            {{if this.depositBusy "Depositing..." "Deposit liquidity"}}
          </button>
        </div>
      </article>
    {{else}}
      <div class="empty-state">
        No `TickPage` accounts were found for this Asset Pool on the selected RPC.
      </div>
    {{/if}}
  </section>

  <section class="panel">
    <div class="panel-heading">
      <div>
        <p class="section-label">Wallet positions</p>
        <h3>Open LP positions in this pool</h3>
      </div>
    </div>

    {{#if this.positions.length}}
      <div class="card-list">
        {{#each this.positions as |position|}}
          <article class="list-card">
            <div class="asset-pool-card-head">
              <div>
                <p class="section-label">{{this.formatTickPercentage position.tick}}</p>
                <strong>{{position.address}}</strong>
              </div>
            </div>
            <div class="service-list compact-list">
              <div class="service-row">
                <span>Tick</span>
                <strong>{{position.tick}}</strong>
              </div>
              <div class="service-row">
                <span>Shares</span>
                <strong>{{position.sharesFormatted}}</strong>
              </div>
              <div class="service-row">
                <span>Redeemable liquidity</span>
                <strong>{{position.redeemableFormatted}}</strong>
              </div>
            </div>
            <label class="input-field">
              <span>Shares to burn</span>
              <input
                type="text"
                value={{get this.withdrawAmounts position.address}}
                placeholder={{position.sharesFormatted}}
                {{on "input" (fn this.updateWithdrawAmount position.address)}}
              />
            </label>
            <button
              type="button"
              class="button button-secondary button-block"
              {{on "click" (fn this.withdraw position.address)}}
            >
              {{if
                (get this.withdrawBusy position.address)
                "Withdrawing..."
                "Withdraw liquidity"
              }}
            </button>
          </article>
        {{/each}}
      </div>
    {{else}}
      <div class="empty-state">
        No LP positions were found for the connected wallet in this pool.
      </div>
    {{/if}}

    {{#if this.actionError}}
      <p class="inline-note tone-danger">{{this.actionError}}</p>
    {{/if}}
    {{#if this.actionMessage}}
      <p class="inline-note">{{this.actionMessage}}</p>
    {{/if}}
  </section>
</section>
