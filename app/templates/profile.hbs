{{page-title "Profile"}}

<section class="page-section">
  <div class="hero-card">
    <p class="section-label">Profile</p>
    <h2>Wallet profile</h2>
    <p class="hero-copy">
      Reference view for the connected wallet with SOL balance and all tracked
      quote asset balances across the protocol.
    </p>
  </div>

  {{#if this.moonoState.walletConnected}}
    <section class="two-column-grid">
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="section-label">Wallet</p>
            <h3>{{this.moonoState.walletAddress}}</h3>
          </div>
        </div>

        <div class="service-list">
          <div class="service-row">
            <span>SOL balance</span>
            <BalanceValue @value={{this.moonoState.walletBalanceText}} />
          </div>
        </div>
      </article>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="section-label">Quote Assets</p>
            <h3>Tracked token balances</h3>
          </div>
        </div>

        {{#if this.moonoState.walletTokenBalances.length}}
          <div class="service-list">
            {{#each this.moonoState.walletTokenBalances as |balance|}}
              <div class="service-row">
                <span>{{balance.mintLabel}}</span>
                <BalanceValue @value={{balance.amountFormatted}} />
              </div>
            {{/each}}
          </div>
        {{else}}
          <div class="empty-state">
            No tracked quote asset balances were found for the connected wallet.
          </div>
        {{/if}}
      </article>
    </section>

    <section class="panel">
      <div class="panel-heading">
        <div>
          <p class="section-label">WSOL</p>
          <h3>Manual wrap / unwrap</h3>
        </div>
      </div>

      <div class="borrow-form-grid">
        <label class="input-field">
          <span>Wrap SOL amount</span>
          <input
            type="text"
            value={{this.wrapAmount}}
            placeholder="1"
            {{on "input" this.updateWrapAmount}}
          />
        </label>

        <div class="profile-action-group">
          <button
            type="button"
            class="button button-primary"
            {{on "click" this.wrapSol}}
          >
            {{if this.wrapBusy "Wrapping..." "Wrap SOL to WSOL"}}
          </button>

          <button
            type="button"
            class="button button-secondary"
            {{on "click" this.unwrapAllWsol}}
          >
            {{if this.unwrapBusy "Unwrapping..." "Unwrap all WSOL to SOL"}}
          </button>
        </div>
      </div>

      {{#if this.actionError}}
        <p class="inline-note tone-danger">{{this.actionError}}</p>
      {{/if}}
      {{#if this.actionMessage}}
        <p class="inline-note">{{this.actionMessage}}</p>
      {{/if}}
    </section>
  {{else}}
    <div class="empty-state">
      Connect a wallet to view the profile and tracked quote asset balances.
    </div>
  {{/if}}
</section>
